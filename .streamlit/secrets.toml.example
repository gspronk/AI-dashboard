# Voorbeeld secrets-bestand voor Streamlit
# Kopieer naar .streamlit/secrets.toml (lokaal) of zet de inhoud op
# Streamlit Community Cloud via Settings -> Secrets.
#
# LET OP: zet .streamlit/secrets.toml in .gitignore — nooit committen.

# Wachtwoord-poort
password = "vervang-dit-door-een-sterk-wachtwoord"

# Persistente opslag via private GitHub Gist (optioneel — laat leeg of weg
# als je lokaal wilt blijven werken met kza_data.json).
#
# Setup-stappen:
# 1. Maak een private gist op https://gist.github.com met bestandsnaam
#    'kza_data.json'. Plak de inhoud van je lokale kza_data.json erin.
# 2. Kopieer het gist-ID uit de URL:
#    https://gist.github.com/<gebruiker>/<GIST_ID>
# 3. Maak een fine-grained Personal Access Token aan op
#    https://github.com/settings/tokens?type=beta
#    Geef alleen 'gists' read+write scope. Geen repo-toegang nodig.
# 4. Vul beide waarden hieronder in.
gist_id = ""
github_token = ""
